padding: 24px 28px;
margin-bottom: 48px;
}

.status-banner-label {
display: inline-block;
padding: 4px 10px;
background: var(–amber-deep);
color: white;
font-size: 11px; font-weight: 700;
letter-spacing: 0.08em;
text-transform: uppercase;
border-radius: 999px;
margin-bottom: 12px;
}

.status-banner h2 {
font-weight: 700; font-size: 20px;
letter-spacing: -0.02em;
margin-bottom: 8px;
color: var(–ink);
}

.status-banner p {
color: var(–ink-soft);
font-size: 15px; line-height: 1.6;
}

.legal-page h2 {
font-weight: 700;
font-size: 24px;
letter-spacing: -0.02em;
margin-top: 40px;
margin-bottom: 14px;
}

.legal-page h3 {
font-weight: 600;
font-size: 17px;
letter-spacing: -0.015em;
margin-top: 24px;
margin-bottom: 10px;
}

.legal-page p {
color: var(–ink-soft);
font-size: 16px;
margin-bottom: 16px;
}

.legal-page ul {
margin: 0 0 16px 22px;
color: var(–ink-soft);
font-size: 16px;
}

.legal-page li { margin-bottom: 8px; }

.legal-page a {
color: var(–amber-deep);
text-decoration: none;
font-weight: 500;
}
.legal-page a:hover { text-decoration: underline; }

.contact-card {
background: var(–off-white);
border: 1px solid var(–line);
border-radius: 16px;
padding: 28px 32px;
margin-top: 48px;
}

.contact-card h3 {
font-size: 12px; font-weight: 700;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–amber-deep);
margin-bottom: 12px;
margin-top: 0;
}

.contact-card p {
color: var(–ink-soft);
font-size: 15px;
margin-bottom: 0;
}

footer {
background: var(–ink); color: var(–white);
padding: 40px 32px;
}
.footer-inner {
max-width: 1280px; margin: 0 auto;
display: flex; justify-content: space-between; align-items: center;
flex-wrap: wrap; gap: 16px;
}
.footer-brand-line {
display: flex; align-items: center; gap: 10px;
