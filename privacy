.footer-brand-line img { width: 24px; height: 24px; }
.footer-brand-line span {
font-weight: 600; font-size: 15px; letter-spacing: -0.02em;
}
.footer-brand-line .by-ahme {
font-weight: 400; font-size: 13px;
color: rgba(255, 255, 255, 0.5);
margin-left: 6px;
