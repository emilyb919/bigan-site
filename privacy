}

.legal-meta {
color: var(–ink-mute);
font-size: 15px;
margin-bottom: 48px;
}

.status-banner {
background: linear-gradient(135deg, rgba(240, 220, 120, 0.15), rgba(240, 165, 0, 0.08));
