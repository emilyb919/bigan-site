<style>
  :root {
    --amber-deep: #C45503;
    --gold: #F0A500;
    --gold-bright: #F0B40F;
    --yellow-bright: #F0E169;
    --ink: #0A0A0A;
    --ink-soft: #2A2A2A;
    --ink-mute: #6B6B6B;
    --ink-faint: #A0A0A0;
    --white: #FFFFFF;
